# ─────────────────────────────────────────────────────────────────────────────
# RISE Tech Village — Poster Design Agent
# Environment Variables Template
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in every value marked <REQUIRED>
#   Values marked <OPTIONAL> have safe defaults — change if needed
#
# SECURITY RULES:
#   • NEVER commit .env to git  (it is in .gitignore)
#   • NEVER share .env in Slack, email, or screenshots
#   • Rotate all keys if .env is ever accidentally exposed
#   • In production, use AWS Secrets Manager or Supabase Vault — not a file
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
DEBUG=true                   # Must be false in production — enforced by config.py
APP_NAME="RISE Poster Agent"

# ── Database ──────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Format: postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres   # <REQUIRED>

# Sync URL for Alembic migrations (same host, different driver)
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres   # <REQUIRED>

# Connection pool settings (tune for Supabase free tier: max 60 connections)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO_SQL=false            # Set true in dev to print all SQL — NEVER in production

# ── LangGraph Checkpointer ────────────────────────────────────────────────────
# Same database — LangGraph stores HITL graph state here
LANGGRAPH_CHECKPOINTER_URL=postgresql+psycopg2://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres   # <REQUIRED>
LANGGRAPH_THREAD_TTL_HOURS=168    # 7 days — how long a paused review can wait

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://<PROJECT-REF>.supabase.co          # <REQUIRED>
SUPABASE_ANON_KEY=eyJ...                                # <REQUIRED> — safe to use in browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...                        # <REQUIRED> — SERVER ONLY, never expose
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase       # <REQUIRED> — Settings → API → JWT Secret

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...    # <REQUIRED>
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── LangSmith Observability ───────────────────────────────────────────────────
# Get from: smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__...       # <REQUIRED>
LANGCHAIN_PROJECT=rise-poster-agent

# ── Image Generation ──────────────────────────────────────────────────────────
# Stability AI (primary) — platform.stability.ai → API Keys
STABILITY_AI_API_KEY=sk-...     # <REQUIRED>
STABILITY_AI_MODEL=stable-diffusion-xl-1024-v1-0

# OpenAI — NOT NEEDED (fallback uses Stability AI alternate style)
# OPENAI_API_KEY=               # <OPTIONAL> — only if you want DALL-E 3 fallback

# ── AWS ───────────────────────────────────────────────────────────────────────
# Create an IAM user with S3 put/get/delete permissions for rise-posters-prod only
AWS_ACCESS_KEY_ID=AKIA...       # <REQUIRED>
AWS_SECRET_ACCESS_KEY=...       # <REQUIRED>
AWS_REGION=ap-southeast-1       # Singapore — closest to Sri Lanka
S3_POSTER_BUCKET=rise-posters-prod
CLOUDFRONT_POSTER_DOMAIN=https://posters.risetechvillage.lk   # <REQUIRED>
S3_URL_EXPIRY_SECONDS=3600      # 1 hour — pre-signed URL expiry

# ── Social Media Platform APIs ────────────────────────────────────────────────
# Instagram — Meta Developer Console → Long-lived access token
INSTAGRAM_ACCESS_TOKEN=...                   # <REQUIRED>
INSTAGRAM_BUSINESS_ACCOUNT_ID=...           # <REQUIRED>

# Facebook — Meta Developer Console → Page access token
FACEBOOK_PAGE_ID=...                         # <REQUIRED>
FACEBOOK_PAGE_ACCESS_TOKEN=...              # <REQUIRED>

# LinkedIn — LinkedIn Developer Portal → OAuth 2.0
LINKEDIN_ORG_ID=...                          # <REQUIRED>
LINKEDIN_ACCESS_TOKEN=...                   # <REQUIRED>

# TikTok — TikTok for Developers → Client credentials
TIKTOK_CLIENT_KEY=...                        # <REQUIRED>
TIKTOK_CLIENT_SECRET=...                    # <REQUIRED>

# ── HITL Review ───────────────────────────────────────────────────────────────
REVIEW_NOTIFICATION_EMAIL=marketing@risetechvillage.lk
REVIEW_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...   # <REQUIRED>
REVIEW_SLACK_CHANNEL=#poster-review-queue
REVIEW_APPROVAL_MIN_SCORE=3.5   # Minimum average score to enable Approve button
REVIEW_MAX_REVISIONS=3          # Maximum revision cycles before status=exhausted
QA_MIN_CONFIDENCE=0.60          # QA confidence below this → auto-regenerate

# ── Publish Schedule (Sri Lanka IST — 24h format) ─────────────────────────────
PUBLISH_HOUR_INSTAGRAM=20       # 8:00 pm
PUBLISH_HOUR_FACEBOOK=20        # 7:30 pm
PUBLISH_MINUTE_FACEBOOK=30
PUBLISH_HOUR_LINKEDIN_AM=9      # 9:00 am
PUBLISH_HOUR_LINKEDIN_PM=19     # 7:00 pm
PUBLISH_HOUR_TIKTOK=21          # 9:00 pm

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the review UI
CORS_ORIGINS=http://localhost:3000
